!is.na(intercept_ball_minus_batter_pos_y_inches),
!is.na(plate_x_rel),
!is.na(plate_z_rel),
!is.na(release_speed),
description %in% c("foul", "hit_into_play", "swinging_strike", "swinging_strike_blocked"),
!str_detect(des, "(?i)bunt") | is.na(des))
library(tidyverse)
df_all_swing <- df_all %>%
filter(!is.na(bat_speed),
!is.na(swing_length),
!is.na(intercept_ball_minus_batter_pos_y_inches),
!is.na(plate_x_rel),
!is.na(plate_z_rel),
!is.na(release_speed),
description %in% c("foul", "hit_into_play", "swinging_strike", "swinging_strike_blocked"),
!str_detect(des, "(?i)bunt") | is.na(des))
# 混合モデル①（GAMM）: Intercept Point
mod_intercept_1 <- bam(
intercept_ball_minus_batter_pos_y_inches ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type + pitch_count +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
library(mgcv)
# 混合モデル①（GAMM）: Intercept Point
mod_intercept_1 <- bam(
intercept_ball_minus_batter_pos_y_inches ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type + pitch_count +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
# 1. 対象変数の非有限値チェック
df_all_swing |>
summarise(
across(
c(plate_x_rel, plate_z_rel),
list(
na  = \(x) sum(is.na(x)),
nan = \(x) sum(is.nan(x)),
inf = \(x) sum(is.infinite(x))
)
)
)
# 2. handedness_type が factor/character か確認（NAレベルも含む）
df_all_swing |> count(handedness_type)
# 3. 範囲確認
df_all_swing |>
summarise(across(c(plate_x_rel, plate_z_rel), range, na.rm = FALSE))
df_all_swing |>
summarise(across(
c(intercept_ball_minus_batter_pos_y_inches, pitch_count),
list(
na  = \(x) sum(is.na(x)),
nan = \(x) sum(is.nan(x)),
inf = \(x) sum(is.infinite(x))
)
))
# 方法①: reframe()
df_all_swing |>
reframe(across(c(plate_x_rel, plate_z_rel), range))
# 方法②: summarise() で明示的に書く（こちらが読みやすい）
df_all_swing |>
summarise(across(
c(plate_x_rel, plate_z_rel),
list(min = min, max = max)
))
# batter_year_id の確認
df_all_swing |>
summarise(
class    = class(batter_year_id),
na       = sum(is.na(batter_year_id)),
n_levels = n_distinct(batter_year_id)
)
df_all_swing <- df_all %>%
filter(!is.na(bat_speed),
!is.na(swing_length),
!is.na(intercept_ball_minus_batter_pos_y_inches),
!is.na(plate_x_rel),
!is.na(plate_z_rel),
!is.na(release_speed),
description %in% c("foul", "hit_into_play", "swinging_strike", "swinging_strike_blocked"),
!str_detect(des, "(?i)bunt") | is.na(des)) |>
mutate(batter_year_id = factor(batter_year_id))
# 混合モデル①（GAMM）: Intercept Point
mod_intercept_1 <- bam(
intercept_ball_minus_batter_pos_y_inches ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type + pitch_count +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
df_all_swing <- df_all %>%
filter(!is.na(bat_speed),
!is.na(swing_length),
!is.na(intercept_ball_minus_batter_pos_y_inches),
!is.na(plate_x_rel),
!is.na(plate_z_rel),
!is.na(release_speed),
description %in% c("foul", "hit_into_play", "swinging_strike", "swinging_strike_blocked"),
!str_detect(des, "(?i)bunt") | is.na(des)) |>
mutate(batter_year_id = factor(batter_year_id),
handedness_type = factor(handedness_type))
# 混合モデル①（GAMM）: Intercept Point
mod_intercept_1 <- bam(
intercept_ball_minus_batter_pos_y_inches ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type + pitch_count +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
# Swing Length
mod_swing_len_1 <- bam(
swing_length ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type + pitch_count +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
# 混合モデル②（GAMM）: Intercept Point
mod_intercept_2 <- bam(
intercept_ball_minus_batter_pos_y_inches ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type +
pitch_count +
s(release_speed) +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
# Swing Length
mod_swing_len_2 <- bam(
swing_length ~
s(plate_x_rel, plate_z_rel, by = handedness_type) +
handedness_type +
pitch_count +
s(release_speed) +
s(batter_year_id, bs = "re"),
data = df_all_swing,
discrete = TRUE,
nthreads = 4
)
# 1. 予測値と残差の算出
df_all_swing <- df_all_swing %>%
mutate(
# 打点前後の偏差
pred_y_1 = predict(mod_intercept_1, newdata = .),
res_y_1 = intercept_ball_minus_batter_pos_y_inches - pred_y_1,
pred_y_2 = predict(mod_intercept_2, newdata = .),
res_y_2 = intercept_ball_minus_batter_pos_y_inches - pred_y_2,
pred_y_3 = predict(mod_intercept_3, newdata = .),
res_y_3 = intercept_ball_minus_batter_pos_y_inches - pred_y_3,
# スイングの長さの偏差
pred_len_1 = predict(mod_swing_len_1, newdata = .),
res_len_1 = swing_length - pred_len_1,
pred_len_2 = predict(mod_swing_len_2, newdata = .),
res_len_2 = swing_length - pred_len_2,
pred_len_3 = predict(mod_swing_len_3, newdata = .),
res_len_3 = swing_length - pred_len_3
)
# 1. 予測値と残差の算出
df_all_swing <- df_all_swing %>%
mutate(
# 打点前後の偏差
pred_y_1 = predict(mod_intercept_1, newdata = .),
res_y_1 = intercept_ball_minus_batter_pos_y_inches - pred_y_1,
pred_y_2 = predict(mod_intercept_2, newdata = .),
res_y_2 = intercept_ball_minus_batter_pos_y_inches - pred_y_2,
# スイングの長さの偏差
pred_len_1 = predict(mod_swing_len_1, newdata = .),
res_len_1 = swing_length - pred_len_1,
pred_len_2 = predict(mod_swing_len_2, newdata = .),
res_len_2 = swing_length - pred_len_2
)
# 2. 打者×年度内での標準化
df_all_swing <- df_all_swing %>%
group_by(batter_year_id) %>%
mutate(
# その打者の普段のバラつきを 1 とした時の「外され度」
timing_index_intercept_1 = as.vector(scale(res_y_1)),
timing_index_swing_len_1 = as.vector(scale(res_len_1)),
timing_index_intercept_2 = as.vector(scale(res_y_2)),
timing_index_swing_len_2 = as.vector(scale(res_len_2))
) %>%
ungroup()
library(scales)
create_timing_performance_plot <- function(df, timing_col, title_name) {
# 1. データの集計
plot_data <- df %>%
mutate(bin = round(!!sym(timing_col), 1)) %>%
group_by(bin) %>%
summarise(
count = n(),
avg_whiff = sum(description %in% c("swinging_strike", "swinging_strike_blocked", "foul_tip")) / n() * 100,
avg_xrv = mean(xrv, na.rm = TRUE) * 150,
avg_gb = sum(bb_type == "ground_ball", na.rm = TRUE) / sum(description == "hit_into_play", na.rm = TRUE) * 100,
.groups = "drop"
)
# 2. 表示範囲内 (-2 to 2) でのスケール最適化
visible_data <- plot_data %>% filter(bin >= -2.0 & bin <= 2.0)
# --- 指標の中心を合わせる計算 ---
# 右軸(%)を左軸(xRV)に重ねるための変換係数 (15% = 3ユニット)
slope <- 0.2
# 各指標のレンジと中心を計算
range_xrv <- range(visible_data$avg_xrv, na.rm = TRUE)
center_xrv <- mean(range_xrv)
range_perc <- range(c(visible_data$avg_whiff, visible_data$avg_gb), na.rm = TRUE)
center_perc <- mean(range_perc)
# パーセンテージ系の中心が xRV の中心に重なるように base_y を算出
# y_mapped = slope * Rate + base_y  =>  base_y = y_mapped - (slope * Rate)
# グリッドを整列させるため、base_y を整数（1の位）で丸めます
base_y <- round(center_xrv - (slope * center_perc))
# 全指標を考慮したプロット領域の決定
y_vals <- c(
visible_data$avg_xrv,
slope * visible_data$avg_whiff + base_y,
slope * visible_data$avg_gb + base_y
)
y_min_dynamic <- floor(min(y_vals, na.rm = TRUE)) - 1
y_max_dynamic <- ceiling(max(y_vals, na.rm = TRUE)) + 1
# 密度棒グラフの高さ
bar_height_max <- (y_max_dynamic - y_min_dynamic) * 0.25
ggplot(plot_data) +
# 背景の密度棒
geom_rect(aes(xmin = bin - 0.04, xmax = bin + 0.04,
ymin = y_min_dynamic,
ymax = y_min_dynamic + (count / max(plot_data$count, na.rm = TRUE) * bar_height_max)),
fill = "#3cb371", alpha = 0.25) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray50", alpha = 0.7) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50", alpha = 0.7) +
# 指標1: xRV / 150 (縁取りされた円)
geom_line(aes(x = bin, y = avg_xrv, color = "xRV / 150"), linewidth = 1.5) +
geom_point(aes(x = bin, y = avg_xrv, color = "xRV / 150"),
size = 4, shape = 21, fill = "white", stroke = 2) +
# 指標2: Whiff Rate (%) (縁取りされた四角)
geom_line(aes(x = bin, y = slope * avg_whiff + base_y, color = "Whiff Rate (%)"), linewidth = 1.2) +
geom_point(aes(x = bin, y = slope * avg_whiff + base_y, color = "Whiff Rate (%)"),
size = 3.5, shape = 22, fill = "white", stroke = 1.5) +
# 指標3: GB Rate (%) (縁取りされた三角)
geom_line(aes(x = bin, y = slope * avg_gb + base_y, color = "GB Rate (%)"), linewidth = 1.2, linetype = "dotted") +
geom_point(aes(x = bin, y = slope * avg_gb + base_y, color = "GB Rate (%)"),
size = 3.5, shape = 24, fill = "white", stroke = 1.5) +
# 軸の設定
scale_y_continuous(
name = "xRV / 150",
breaks = seq(y_min_dynamic, y_max_dynamic, by = 2),
sec.axis = sec_axis(
trans = ~ (. - base_y) / slope,
name = "Whiff / GB Rate (%)",
breaks = seq(0, 100, by = 15)
)
) +
scale_x_continuous(
name = "Timing Index",
breaks = seq(-2, 2, by = 0.5)
) +
coord_cartesian(xlim = c(-2, 2), ylim = c(y_min_dynamic, y_max_dynamic)) +
scale_color_manual(values = c("xRV / 150" = "#D32F2F", "Whiff Rate (%)" = "#1565C0", "GB Rate (%)" = "#2E7D32")) +
labs(
title = paste("Timing Index:", title_name),
subtitle = "MLB 2024 ~ 2025",
x = "Timing Index (SD)",
caption = "Data: Baseball Savant",
color = NULL
) +
theme_minimal() +
theme(
legend.position = c(0.5, 0.92),
legend.justification = c(0.5, 1),
legend.direction = "horizontal",
legend.background = element_rect(fill = alpha("white", 0.9), color = "gray40", linewidth = 0.5),
legend.margin = margin(6, 12, 6, 12),
legend.text = element_text(size = 18),
legend.key = element_blank(),
legend.key.size = unit(2.5, "lines"),
plot.title = element_text(face = "bold", size = 30, margin = margin(b = 10)),
plot.subtitle = element_text(size = 20, color = "gray40", margin = margin(b = 10)),
axis.title = element_text(size = 25, face = "bold", margin = margin(r = 15, l = 15, t = 15)),
axis.text = element_text(size = 20, face = "italic"),
panel.grid.minor = element_blank(),
panel.background = element_rect(fill = "gray97"),
plot.caption = element_text(size = 15, color = "gray60")
)
}
pitcher_stats <- df_all_swing %>%
group_by(pitcher_id, year) %>%
summarise(
timing_disruption_y_1 = round(mean(abs(timing_index_intercept_1), na.rm = TRUE), 3),
timing_disruption_len_1 = round(mean(abs(timing_index_swing_len_1), na.rm = TRUE), 3),
timing_disruption_y_2 = round(mean(abs(timing_index_intercept_2), na.rm = TRUE), 3),
timing_disruption_len_2 = round(mean(abs(timing_index_swing_len_2), na.rm = TRUE), 3),
timing_disruption_y_3 = round(mean(abs(timing_index_intercept_3), na.rm = TRUE), 3),
timing_disruption_len_3 = round(mean(abs(timing_index_swing_len_3), na.rm = TRUE), 3),
timing_bias_y_1 = round(mean(timing_index_intercept_1, na.rm = TRUE), 3),
timing_bias_len_1 = round(mean(timing_index_swing_len_1, na.rm = T), 3),
timing_bias_y_2 = round(mean(timing_index_intercept_2, na.rm = TRUE), 3),
timing_bias_len_2 = round(mean(timing_index_swing_len_2, na.rm = T), 3),
timing_bias_y_3 = round(mean(timing_index_intercept_3, na.rm = TRUE), 3),
timing_bias_len_3 = round(mean(timing_index_swing_len_3, na.rm = T), 3),
n_swings = n(),
run_value_avg = round(mean(run_value_avg, na.rm = T), 3),
xrun_value = round(mean(xrv, na.rm = T), 3),
whiff_rate = round(sum(description %in% c("swinging_strike", "swinging_strike_blocked", "foul_tip")) / n() * 100, 1),
foul_rate = round(sum(description %in% c("foul")) / n() * 100, 1),
bbe_rate   = round(sum(description %in% c("hit_into_play")) / n() * 100, 1),
ev_avg = round(mean(launch_speed, na.rm = T), 1),
adj_ev_avg = round(mean(hyper_speed, na.rm = T), 1),
gb_rate = round(sum(bb_type == "ground_ball", na.rm = T) / sum(description %in% c("hit_into_play")) * 100, 1),
ld_rate = round(sum(bb_type == "line_drive", na.rm = T) / sum(description %in% c("hit_into_play")) * 100, 1),
fb_rate = round(sum(bb_type == "fly_ball", na.rm = T) / sum(description %in% c("hit_into_play")) * 100, 1),
pu_rate = round(sum(bb_type == "popup", na.rm = T) / sum(description %in% c("hit_into_play")) * 100, 1),
.groups = "drop"
) %>%
left_join(Name, by = c("pitcher_id" = "MLBAMID")) %>%
filter(n_swings >= 500)
# 探索するオフセットの範囲を設定（-1.5から1.5まで0.1刻み）
offsets <- seq(-2, 2, by = 0.1)
# 結果を格納するデータフレーム
search_results_xrv <- data.frame()
for(off in offsets) {
# スイング単位での計算と集計
temp_stats <- df_all_swing %>%
group_by(pitcher_id, year) %>%
summarise(
# Intercept と Swing Length の「新しい基準点」からの外され度（絶対値）
new_disruption_y = mean(abs(timing_index_intercept_1 - off), na.rm = TRUE),
new_disruption_len = mean(abs(timing_index_swing_len_1 - off), na.rm = TRUE),
# 目的変数: xRV (Expected Run Value) の平均
avg_xrv = mean(xrv, na.rm = TRUE),
n_swings = n(),
.groups = "drop"
) %>%
filter(n_swings >= 500)
# 相関を計算（xRV は低い方が投手として良いため、絶対値で評価）
cor_xrv_y = cor(temp_stats$new_disruption_y, temp_stats$avg_xrv, use = "complete.obs")
cor_xrv_len = cor(temp_stats$new_disruption_len, temp_stats$avg_xrv, use = "complete.obs")
# 結果を保存
search_results_xrv <- bind_rows(
search_results_xrv,
data.frame(offset = off, cor_xrv_y = cor_xrv_y, cor_xrv_len = cor_xrv_len)
)
}
# 1. xRVと最も相関が強い Intercept Disruption の基準点
best_off_xrv_y <- search_results_xrv$offset[which.max(abs(search_results_xrv$cor_xrv_y))]
print(paste("Best offset for xRV (Intercept Disruption):", best_off_xrv_y))
# 2. xRVと最も相関が強い Swing Length Disruption の基準点
best_off_xrv_len <- search_results_xrv$offset[which.max(abs(search_results_xrv$cor_xrv_len))]
print(paste("Best offset for xRV (Swing Length Disruption):", best_off_xrv_len))
# 可視化：基準点を変えると xRV との相関がどう動くか
ggplot(search_results_xrv, aes(x = offset)) +
geom_line(aes(y = abs(cor_xrv_y), color = "xRV vs Intercept Disruption"), linewidth = 1) +
geom_line(aes(y = abs(cor_xrv_len), color = "xRV vs Swing Length Disruption"), linewidth = 1) +
theme_minimal() +
labs(title = "Finding Optimal Reference Points for xRV",
x = "Offset from Model 0",
y = "Correlation Coefficient (Absolute |r|)",
color = "Metric Pair")
